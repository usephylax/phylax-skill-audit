{
  "name": "phylax-skill-audit",
  "version": "0.2.3",
  "description": "Pre-install security audit for Base-chain agent skills. Deterministic ALLOW/WARN/DENY verdict.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "phylax": "dist/cli.js"
  },
  "files": [
    "dist",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node dist/cli.js",
    "bankr:sync": "node scripts/bankr-sync-profile.mjs",
    "bankr:x402:onboard": "node scripts/bankr-x402-onboard.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usephylax/phylax-skill-audit.git"
  },
  "homepage": "https://usephylax.com",
  "bugs": {
    "url": "https://github.com/usephylax/phylax-skill-audit/issues"
  },
  "keywords": [
    "security",
    "audit",
    "base",
    "agent-skills",
    "x402",
    "web3"
  ],
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
