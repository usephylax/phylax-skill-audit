{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "node_modules/phylax-skill-audit/rules/**",
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.usephylax.com" }],
      "destination": "https://usephylax.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.usephylax.com" }],
      "destination": "https://usephylax.com/:path*",
      "permanent": true
    }
  ]
}
